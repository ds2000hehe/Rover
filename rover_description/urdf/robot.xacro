<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="black" value="0 0 0 1"/>
    <xacro:property name="blue" value="0 0 1 1"/>
    <xacro:property name="grey" value="0.5 0.5 0.5 1"/>


    <xacro:property name="wheel_radius" value="0.034"/>
    <xacro:property name="wheel_thickness" value="0.026"/>
    <xacro:property name="wheel_mass" value="0.05"/>
    <xacro:property name="front_wheel_offset_x" value="0.085"/>
    <xacro:property name="rear_wheel_offset_x" value="0.085"/>
    <xacro:property name="front_wheel_offset_y" value="0.038782"/>
    <xacro:property name="rear_wheel_offset_y" value="0.070718"/>
    <xacro:property name="wheel_offset_z" value="0.018845"/>
    <xacro:property name="base_mass" value="2.0"/>

    <link name="base_link"/>

    <link name="body_link">

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <material name="grey">
                 <color rgba="${grey}"/>
            </material>
            <geometry>
                <mesh
                    filename="package://rover_description/urdf/meshes/rover_base.stl"
                    scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <geometry>
                <mesh
                    filename="package://rover_description/urdf/meshes/rover_base.stl"
                    scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${base_mass}"/>
            <inertia
                ixx="0.1"
                ixy="0.0"
                ixz="0.0"
                iyy="0.1"
                iyz="0.0"
                izz="0.1"/>
        </inertial>

    </link>

    <joint name="body_joint" type="fixed">
        <parent link="base_link"/>
        <child link="body_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>


    <link name="back_left_wheel_link">

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <material name="back">
                 <color rgba="${black}"/>
            </material>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="0.0001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.0001"
                iyz="0.0"
                izz="0.0001"/>
        </inertial>

    </link>

    <joint name="back_left_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="back_left_wheel_link"/>
        <origin
            xyz="${-rear_wheel_offset_x} ${-rear_wheel_offset_y} ${wheel_offset_z}"
            rpy="0 0 ${pi}"/>
        <axis xyz="1 0 0"/>
    </joint>

    <!-- ================= BACK RIGHT WHEEL ================= -->

    <link name="back_right_wheel_link">

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <material name="back">
                 <color rgba="${black}"/>
            </material>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="0.0001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.0001"
                iyz="0.0"
                izz="0.0001"/>
        </inertial>

    </link>

    <joint name="back_right_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="back_right_wheel_link"/>
        <origin
            xyz="${rear_wheel_offset_x} ${-rear_wheel_offset_y} ${wheel_offset_z}"
            rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

    <!-- ================= FRONT LEFT WHEEL ================= -->

    <link name="front_left_wheel_link">

        <visual>
            <origin xyz="0 0 0" rpy="-${pi/2} 0 ${pi/2}"/>
            <material name="back">
                 <color rgba="${black}"/>
            </material>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="0.0001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.0001"
                iyz="0.0"
                izz="0.0001"/>
        </inertial>

    </link>

    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="front_left_wheel_link"/>
        <origin
            xyz="${-front_wheel_offset_x} ${front_wheel_offset_y} ${wheel_offset_z}"
            rpy="0 0 ${pi}"/>
        <axis xyz="1 0 0"/>
    </joint>

    <!-- ================= FRONT RIGHT WHEEL ================= -->

    <link name="front_right_wheel_link">

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <material name="black">
                 <color rgba="${black}"/>
            </material>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <cylinder
                    radius="${wheel_radius}"
                    length="${wheel_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="0.0001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.0001"
                iyz="0.0"
                izz="0.0001"/>
        </inertial>

    </link>

    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="front_right_wheel_link"/>
        <origin
            xyz="${front_wheel_offset_x} ${front_wheel_offset_y} ${wheel_offset_z}"
            rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

</robot>